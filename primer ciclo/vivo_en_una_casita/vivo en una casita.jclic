    <style name="targetError" base="target" foreground="0xFF0000" />
    <style name="target" base="default" foreground="0x0000FF" target="true" />
    <style name="default" family="Arial" background="0xFFFFFF" size="20" bold="false" italic="false" tabWidth="12" />
    <section>
     <p family="Arial" background="0xFFFFFF" Alignment="0">
      <text size="20">Yo vivo en una </text>
      <target>
       <answer>casita</answer>
       <optionList>
        <option>barrio</option>
        <option>casita</option>
        <option>país</option>
       </optionList>
