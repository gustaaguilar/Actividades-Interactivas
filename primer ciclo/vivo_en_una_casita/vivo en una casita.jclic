          <font family="Arial" size="48" bold="true" />
          <color background="0xFFFFFF" inactive="0xFFFFFF" />
         </style>
        </cell>
       </info>
       <text>casita</text>
      </target>
      <text size="20">.</text>
     </p>
     <p family="Arial" background="0xFFFFFF" Alignment="0">
      <text size="20">En un </text>
      <target>
       <answer>barrio</answer>
       <optionList>
        <option>casita</option>
        <option>planeta</option>
        <option>barrio</option>
       </optionList>
       <text>barrio</text>
      </target>
      <text size="20"> de la </text>
      <target>ciudad.</target>
     </p>
     <p family="Arial" background="0xFFFFFF" Alignment="0">
      <text size="20">De un </text>
      <target>
       <answer>país</answer>
