      <target>
       <answer>país</answer>
       <response fill="." length="4" maxLength="4" />
       <text>país</text>
      </target>
      <text size="48"> a la </text>
      <target>
       <answer>ciudad</answer>
       <response fill="." length="6" maxLength="6" />
       <text>ciudad</text>
      </target>
      <text size="48">.</text>
     </p>
    </section>
   </document>
   <evaluator class="@ComplexEvaluator" />
  </activity>
  <activity class="@puzzles.DoublePuzzle" name="rompe1" code="">
   <description />
   <messages>
    <cell type="initial">
