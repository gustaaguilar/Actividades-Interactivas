       <answer>país</answer>
       <optionList>
        <option>barrio</option>
        <option>nave</option>
        <option>país</option>
       </optionList>
       <text>país</text>
      </target>
      <text family="Arial" background="0xFFFFFF"> a</text>
      <text size="20"> la </text>
      <target>
       <answer>ciudad</answer>
       <optionList>
        <option>continente</option>
        <option>planeta</option>
        <option>ciudad</option>
       </optionList>
