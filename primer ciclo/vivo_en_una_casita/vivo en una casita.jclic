      <text size="20">.</text>
     </p>
     <p family="Arial" background="0xFFFFFF" Alignment="0">
      <text size="20">De un </text>
      <target>
       <answer>continente</answer>
       <optionList>
        <option>continente</option>
        <option>planeta</option>
        <option>casita</option>
       </optionList>
       <text>continente</text>
      </target>
      <text size="20">.</text>
     </p>
     <p family="Arial" background="0xFFFFFF" Alignment="0">
      <text size="20">Que en este </text>
      <target>
       <answer>planeta</answer>
       <optionList>
        <option>casita</option>
        <option>planeta</option>
        <option>nave</option>
       </optionList>
       <text>planeta</text>
      </target>
      <text size="20"> está.</text>
     </p>
     <p family="Arial" background="0xFFFFFF" Alignment="0">
      <text size="20">En mi </text>
      <target>
       <answer>nave</answer>
       <optionList>
        <option>nave</option>
        <option>casita</option>
        <option>continente</option>
       </optionList>
       <text>nave</text>
      </target>
      <text size="20"> fabulosa,</text>
     </p>
     <p family="Arial" background="0xFFFFFF" Alignment="0">
      <text size="20">voy y vengo sin parar.</text>
     </p>
     <p family="Arial" background="0xFFFFFF" Alignment="0">
      <text size="20">Del</text>
      <text family="Arial" background="0xFFFFFF"> </text>
      <target>
       <answer>planeta</answer>
       <optionList>
        <option>nave</option>
        <option>planeta</option>
        <option>continente</option>
       </optionList>
       <text>planeta</text>
      </target>
      <text family="Arial" background="0xFFFFFF"> a</text>
