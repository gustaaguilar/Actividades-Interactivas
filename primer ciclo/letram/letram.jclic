  <activity class="@text.FillInBlanks" name="camisa" code="">
   <description />
   <messages>
    <cell type="initial">
     <style borderStroke="0.7" markerStroke="5.0">
      <font family="Arial" size="36" bold="true" />
      <color alternative="0x009900" />
      <gradient source="0x009933" dest="0xFFFFFF" angle="0" />
     </style>
     <p>Completa con ma - me - mi - mo - mu</p>
    </cell>
    <cell avoidOverlapping="true" image="bienhecho.jpg" type="final">
