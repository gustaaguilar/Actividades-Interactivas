    <text>
     <row>C********I**</row>
     <row>*OÁA*****N**</row>
     <row>**RI*****D**</row>
     <row>**BR*****I**</row>
     <row>**OOE****O**</row>
     <row>**LT*C***S**</row>
     <row>***S**A*****</row>
     <row>*FRIO**M****</row>
     <row>***H****I***</row>
     <row>*********N**</row>
     <row>******OTOÑO*</row>
     <row>***********S</row>
    </text>
   </textGrid>
   <clues>
