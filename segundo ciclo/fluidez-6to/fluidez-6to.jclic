    <clue id="1">FRIO</clue>
    <clue id="2">INDIOS</clue>
    <clue id="3">CORRECAMINOS</clue>
    <clue id="4">OTOÑO</clue>
    <clue id="5">ÁRBOL</clue>
   </clues>
