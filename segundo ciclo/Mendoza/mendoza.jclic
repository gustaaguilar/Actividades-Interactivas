  <activity class="@puzzles.DoublePuzzle" name="1" code="">
   <description />
   <messages>
    <cell type="initial">
     <style>
      <font family="Arial" size="28" bold="true" />
      <gradient source="0x009933" dest="0xFFFFFF" angle="0" />
     </style>
     <p>Armá el nombre del departamento de Mendoza.</p>
    </cell>
    <cell avoidOverlapping="true" image="bienhecho.jpg" type="final">
