      <font family="Arial" size="28" bold="true" />
      <gradient source="0xCC00CC" dest="0xFFFFFF" angle="0" />
     </style>
     <p>¡Muy bien!</p>
    </cell>
   </messages>
   <settings margin="8" dragCells="true" report="true" reportActions="false">
    <container bgColor="0xFFFFFF">
     <gradient source="0x666600" dest="0xFFFFFF" angle="0" />
     <image name="malargüe-resized1.jpg" tiled="false" />
     <counters time="true" actions="true" score="true" />
    </container>
    <window bgColor="0xC0C0C0" transparent="true" border="true" />
   </settings>
   <cells rows="1" cols="8" cellWidth="40.0" cellHeight="64.0" border="true">
    <style borderStroke="0.7" markerStroke="5.0">
     <font family="Arial" size="48" bold="true" />
     <gradient source="0xFF0000" dest="0xFFFFFF" angle="0" />
    </style>
    <shaper class="@Rectangular" cols="8" rows="1" />
