  <activity class="@textGrid.WordSearch" name="sopa1" code="">
   <description />
   <messages>
    <cell type="initial">
     <style>
      <font family="Arial" size="28" bold="true" />
      <color background="0xFF9966" />
     </style>
     <p>Encontrá 10 palabras del cuento escondidas.</p>
    </cell>
    <cell avoidOverlapping="true" image="i02-i01-bienhecho.jpg" type="final">
     <style>
      <font family="Arial" size="28" bold="true" />
      <color background="0x00CC00" />
     </style>
     <p>¡Muy bien!</p>
    </cell>
   </messages>
   <settings margin="8" report="true" reportActions="false">
    <helpWindow showSolution="true" />
    <container bgColor="0xC0C0C0">
     <gradient source="0x009999" dest="0xFFFFFF" angle="0" />
     <counters time="true" actions="true" score="true" />
    </container>
    <window bgColor="0xC0C0C0" border="true">
     <gradient source="0x999900" dest="0xFFFFFF" angle="0" />
    </window>
   </settings>
   <textGrid rows="10" columns="7" cellWidth="41.0" cellHeight="44.0" border="true">
    <style margin="3">
     <font family="Arial" size="20" bold="true" />
     <color foreground="0xFFFFFF" background="0x660066" />
    </style>
    <text>
     <row>PASCUALITO</row>
     <row>ARQUERO***</row>
     <row>**TREN****</row>
     <row>HORMIGUERO</row>
     <row>*CARLOS***</row>
     <row>**N*******</row>
     <row>TALENTO***</row>
    </text>
   </textGrid>
   <clues>
    <clue id="0">CARLOS</clue>
    <clue id="1">PASCUALITO</clue>
    <clue id="2">ARQUERO</clue>
    <clue id="3">TALENTO</clue>
    <clue id="4">HORMIGUERO</clue>
    <clue id="5">TREN</clue>
   </clues>
   <cells rows="3" cols="2" border="true" image="20.png" id="secondary">
    <style />
    <shaper class="@ClassicJigSaw" cols="2" rows="3" />
   </cells>
   <layout position="AB" />
  </activity>
