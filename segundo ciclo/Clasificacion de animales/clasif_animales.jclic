  <activity class="@text.FillInBlanks" name="fill1" code="">
   <description />
   <messages>
    <cell type="initial">
     <style>
      <font family="Arial" size="26" bold="true" />
      <color foreground="0xFFFFFF" background="0x1A4A1A" />
     </style>
     <media type="PLAY_AUDIO" level="1" file="cons_completar.mp3" />
     <p>Completá la oración con la palabra que falta.</p>
    </cell>
    <cell type="final">
     <style>
      <font family="Arial" size="26" bold="true" />
      <color foreground="0xFFFF00" background="0x1A4A1A" />
     </style>
     <media type="PLAY_AUDIO" level="1" file="muy_bien.mp3" />
     <p>¡Muy bien!</p>
    </cell>
   </messages>
   <settings margin="8" report="true" reportActions="false">
    <container bgColor="0x1A4A1A">
     <image name="carn_aguila.png" tiled="true" />
     <counters time="true" actions="true" score="true" />
    </container>
    <window bgColor="0xFFFFFF" border="true">
     <size width="580" height="120" />
    </window>
   </settings>
   <document>
    <style name="targetError" base="target" foreground="0xFF0000" />
    <style name="target" base="default" foreground="0x1A4A1A" target="true" />
    <style name="default" family="Arial" background="0xFFFFFF" size="26" bold="false" italic="false" tabWidth="12" />
    <section>
     <p family="Arial" background="0xFFFFFF">
      <text size="26">El águila es un animal </text>
      <target>
       <answer>carnivoro</answer>
       <answer>carnívoro</answer>
       <response fill="_" length="9" maxLength="9" />
       <text>carnívoro</text>
      </target>
      <text size="26"> porque se alimenta de otros animales.</text>
     </p>
    </section>
   </document>
   <evaluator class="@ComplexEvaluator" />
  </activity>
