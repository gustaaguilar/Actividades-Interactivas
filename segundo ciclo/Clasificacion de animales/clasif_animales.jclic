 <activities>
  <activity class="@puzzles.ExchangePuzzle" name="cierre">
   <messages>
    <cell type="initial">
     <style borderStroke="0.7" markerStroke="5.0">
      <font family="Arial" size="26" bold="true" />
      <color foreground="0xFFFFFF" background="0x1a4a1a" />
      <gradient source="0x2d7a2d" dest="0x1a4a1a" angle="275" />
     </style>
     <p>¡Último rompecabezas! ¡Casi terminás!</p>
     <media type="PLAY_AUDIO" level="1" file="cons_portada.mp3" />
    </cell>
    <cell avoidOverlapping="true" image="i03-i01-bienhecho.jpg" type="final">
     <style>
      <font family="Arial" size="26" bold="true" />
      <color foreground="0xFFFFFF" background="0x1a4a1a" />
     </style>
     <p>¡Muy bien! ¡Terminaste!</p>
     <media type="PLAY_AUDIO" level="1" file="muy_bien.mp3" />
    </cell>
   </messages>
   <settings margin="8" dragCells="true" report="true" reportActions="false">
    <container bgColor="0x1a4a1a">
     <counters time="true" actions="true" score="true" />
    </container>
    <window bgColor="0xFFFFFF" border="true" />
   </settings>
   <cells rows="2" cols="3" border="true" image="cierre-resized2.jpg">
    <style />
    <shaper class="@Rectangular" cols="3" rows="2" />
   </cells>
   <scramble times="31" />
  </activity>
