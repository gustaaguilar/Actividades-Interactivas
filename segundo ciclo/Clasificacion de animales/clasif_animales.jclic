    <container bgColor="0x33CCFF">
     <gradient source="0x009999" dest="0x0A2A0A" angle="0" />
     <counters time="true" actions="true" score="true" />
    </container>
    <window bgColor="0xFF0000" border="true" />
   </settings>
   <textGrid rows="10" columns="10" cellWidth="44.0" cellHeight="40.0" border="true">
    <style margin="2">
     <font family="Arial" size="20" bold="true" />
     <color foreground="0xFFFF00" background="0x1A4A1A" />
    </style>
    <text>
     <row>*MAMÍFERO*</row>
     <row>**********</row>
     <row>***REPTIL*</row>
     <row>ANFIBIO***</row>
     <row>**AVE*****</row>
     <row>******PEZ*</row>
     <row>**INSECTO*</row>
     <row>CARNÍVORO*</row>
     <row>**********</row>
     <row>****RANA**</row>
    </text>
   </textGrid>
   <clues>
    <clue id="0">MAMÍFERO</clue>
    <clue id="1">REPTIL</clue>
    <clue id="2">ANFIBIO</clue>
    <clue id="3">AVE</clue>
    <clue id="4">PEZ</clue>
    <clue id="5">INSECTO</clue>
    <clue id="6">CARNÍVORO</clue>
    <clue id="7">RANA</clue>
