    <section>
     <p family="Arial" background="0xFFFFFF">
      <text size="26">La abeja es un animal </text>
      <target>
       <answer>invertebrado</answer>
       <response fill="_" length="12" maxLength="12" />
       <text>invertebrado</text>
      </target>
      <text size="26"> porque no tiene columna vertebral.</text>
     </p>
    </section>
   </document>
   <evaluator class="@ComplexEvaluator" />
